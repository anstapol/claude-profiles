#!/usr/bin/env python3
"""claude-profiles: Switch between Claude Max accounts instantly.

Usage:
    claude-profiles save <name> [-y]      Save current credentials as a named profile
                                          (-y/--yes overwrites without prompting)
    claude-profiles use <name>            Switch to a saved profile
    claude-profiles refresh <name>        Re-save current credentials into <name>
                                          (only if the active account matches)
    claude-profiles list                  List saved profiles
    claude-profiles rm <name>             Remove a saved profile
    claude-profiles rename <old> <new>    Rename a saved profile
    claude-profiles current               Show which account is active

Profile names may contain letters, digits, hyphens, and underscores.
Profiles are stored in ~/.claude/profiles/<name>/
Requires: macOS or Linux, Python 3.6+
"""

import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
from datetime import datetime

PROFILES_DIR = os.path.expanduser("~/.claude/profiles")
CLAUDE_JSON = os.path.expanduser("~/.claude.json")
IS_MACOS = sys.platform == "darwin"

if IS_MACOS:
    KEYCHAIN_SERVICE = "Claude Code-credentials"
    KEYCHAIN_ACCOUNT = os.environ.get("USER")
    if not KEYCHAIN_ACCOUNT:
        print("Error: $USER is not set. Cannot determine keychain account.", file=sys.stderr)
        sys.exit(1)
else:
    CREDENTIALS_JSON = os.path.expanduser("~/.claude/.credentials.json")

# Keys in ~/.claude.json that belong to the logged-in account. Snapshotted on
# `save`, restored (or cleared) on `use`.
ACCOUNT_KEYS = ("oauthAccount", "hasAvailableSubscription", "userID")

# Per-account caches in ~/.claude.json. We don't snapshot these — we clear them
# on `use` so Claude Code re-fetches them for the new account on next startup.
VOLATILE_ACCOUNT_KEYS = (
    "cachedDynamicConfigs",
    "cachedExperimentFeatures",
    "cachedGrowthBookFeatures",
    "cachedStatsigGates",
    "cachedExtraUsageDisabledReason",
    "s1mAccessCache",
    "s1mNonSubscriberAccessCache",
    "passesEligibilityCache",
    "passesLastSeenRemaining",
    "overageCreditGrantCache",
    "subscriptionNoticeCount",
)


def validate_name(name):
    if not name or not re.fullmatch(r'[a-zA-Z0-9_-]+', name):
        print(f"Error: Invalid profile name '{name}'. Use only letters, digits, hyphens, and underscores.", file=sys.stderr)
        sys.exit(1)


def run(cmd, input_data=None):
    r = subprocess.run(cmd, capture_output=True, text=True, input=input_data)
    return r.returncode, r.stdout, r.stderr


def read_credentials():
    if IS_MACOS:
        code, out, err = run([
            "security", "find-generic-password",
            "-s", KEYCHAIN_SERVICE, "-a", KEYCHAIN_ACCOUNT, "-w"
        ])
        if code != 0:
            return None
        return out.strip()
    else:
        try:
            with open(CREDENTIALS_JSON, "r") as f:
                return f.read().strip()
        except FileNotFoundError:
            return None


def write_credentials(data):
    if IS_MACOS:
        # -U updates the existing item atomically. The previous delete-then-add
        # sequence could leave no entry at all if the second call failed.
        code, _, err = run([
            "security", "add-generic-password", "-U",
            "-s", KEYCHAIN_SERVICE, "-a", KEYCHAIN_ACCOUNT,
            "-w", data,
        ])
        if code != 0:
            print(f"Error writing keychain: {err}", file=sys.stderr)
            sys.exit(1)
    else:
        dir_name = os.path.dirname(CREDENTIALS_JSON)
        fd, tmp_path = tempfile.mkstemp(dir=dir_name, suffix=".tmp")
        try:
            with os.fdopen(fd, "w") as f:
                f.write(data)
                f.write("\n")
            os.chmod(tmp_path, 0o600)
            os.rename(tmp_path, CREDENTIALS_JSON)
        except BaseException:
            os.unlink(tmp_path)
            raise


def read_claude_json():
    try:
        with open(CLAUDE_JSON, "r") as f:
            return json.load(f)
    except FileNotFoundError:
        print("Error: ~/.claude.json not found — is Claude Code installed?", file=sys.stderr)
        sys.exit(1)


def write_claude_json(data):
    tmp_dir = os.path.expanduser("~/.claude")
    os.makedirs(tmp_dir, exist_ok=True)
    fd, tmp_path = tempfile.mkstemp(dir=tmp_dir, suffix=".tmp")
    try:
        with os.fdopen(fd, "w") as f:
            json.dump(data, f, indent=2)
            f.write("\n")
        os.rename(tmp_path, CLAUDE_JSON)
    except BaseException:
        os.unlink(tmp_path)
        raise


def profile_dir(name):
    return os.path.join(PROFILES_DIR, name)


def profile_creds_path(pdir):
    """Return the credentials file path inside a profile, supporting the
    pre-rename `keychain.json` filename. Returns None if neither exists."""
    new = os.path.join(pdir, "credentials.json")
    if os.path.exists(new):
        return new
    legacy = os.path.join(pdir, "keychain.json")
    if os.path.exists(legacy):
        return legacy
    return None


def write_atomic(path, data, mode=0o600):
    dir_name = os.path.dirname(path)
    fd, tmp_path = tempfile.mkstemp(dir=dir_name, suffix=".tmp")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(data)
        os.chmod(tmp_path, mode)
        os.rename(tmp_path, path)
    except BaseException:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise


def saved_str(path):
    """Return ' (saved YYYY-MM-DD)' for the given file, or ''."""
    try:
        mtime = os.path.getmtime(path)
        return f" (saved {datetime.fromtimestamp(mtime).strftime('%Y-%m-%d')})"
    except OSError:
        return ""


def write_profile(pdir, creds_data, cdata):
    """Write credentials.json + account.json into pdir. Returns account_info."""
    write_atomic(os.path.join(pdir, "credentials.json"), creds_data)
    account_info = {k: cdata[k] for k in ACCOUNT_KEYS if k in cdata}
    write_atomic(
        os.path.join(pdir, "account.json"),
        json.dumps(account_info, indent=2) + "\n",
    )
    return account_info


def cmd_save(name, force=False):
    validate_name(name)
    pdir = profile_dir(name)
    if os.path.isdir(pdir) and not force:
        resp = input(f"Profile '{name}' already exists. Overwrite? [y/N] ").strip().lower()
        if resp not in ("y", "yes"):
            print("Aborted.")
            sys.exit(0)

    creds_data = read_credentials()
    if not creds_data:
        print("No Claude credentials found. Are you logged in?", file=sys.stderr)
        sys.exit(1)
    cdata = read_claude_json()

    os.makedirs(pdir, exist_ok=True)
    os.chmod(pdir, 0o700)
    account_info = write_profile(pdir, creds_data, cdata)

    email = account_info.get("oauthAccount", {}).get("emailAddress", "unknown")
    display = account_info.get("oauthAccount", {}).get("displayName", "")
    try:
        tier = json.loads(creds_data).get("claudeAiOauth", {}).get("rateLimitTier", "")
    except (json.JSONDecodeError, AttributeError):
        tier = ""

    print(f"Saved profile '{name}': {display} <{email}> [{tier}]")


def cmd_refresh(name):
    validate_name(name)
    pdir = profile_dir(name)
    if not os.path.isdir(pdir):
        print(f"Profile '{name}' not found. Use 'claude-profiles list' to see available profiles.", file=sys.stderr)
        sys.exit(1)

    creds_data = read_credentials()
    if not creds_data:
        print("No Claude credentials found. Are you logged in?", file=sys.stderr)
        sys.exit(1)
    cdata = read_claude_json()
    current_email = cdata.get("oauthAccount", {}).get("emailAddress")

    profile_email = None
    try:
        with open(os.path.join(pdir, "account.json")) as f:
            profile_email = json.load(f).get("oauthAccount", {}).get("emailAddress")
    except (FileNotFoundError, json.JSONDecodeError):
        pass

    if not profile_email:
        print(
            f"Profile '{name}' has no recorded email. Use "
            f"'claude-profiles save {name} -y' to (re)create it.",
            file=sys.stderr,
        )
        sys.exit(1)
    if profile_email != current_email:
        print(
            f"Refusing to refresh: profile '{name}' is for <{profile_email}>, "
            f"but the active account is <{current_email}>.",
            file=sys.stderr,
        )
        sys.exit(1)

    write_profile(pdir, creds_data, cdata)
    print(f"Refreshed profile '{name}': <{current_email}>")


def cmd_use(name):
    validate_name(name)
    pdir = profile_dir(name)
    if not os.path.isdir(pdir):
        print(f"Profile '{name}' not found. Use 'claude-profiles list' to see available profiles.", file=sys.stderr)
        sys.exit(1)

    creds_path = profile_creds_path(pdir)
    if not creds_path:
        print(f"Error: Profile '{name}' is missing its credentials file.", file=sys.stderr)
        sys.exit(1)
    with open(creds_path, "r") as f:
        creds_data = f.read().strip()
    try:
        json.loads(creds_data)
    except json.JSONDecodeError as e:
        print(f"Error: Profile '{name}' has invalid credentials JSON: {e}", file=sys.stderr)
        sys.exit(1)

    with open(os.path.join(pdir, "account.json"), "r") as f:
        account_info = json.load(f)

    write_credentials(creds_data)

    cdata = read_claude_json()
    for key in ACCOUNT_KEYS:
        if key in account_info:
            cdata[key] = account_info[key]
        elif key in cdata:
            del cdata[key]
    # Drop per-account caches so Claude Code re-fetches them for the new account.
    for key in VOLATILE_ACCOUNT_KEYS:
        cdata.pop(key, None)

    write_claude_json(cdata)

    email = account_info.get("oauthAccount", {}).get("emailAddress", "unknown")
    display = account_info.get("oauthAccount", {}).get("displayName", "")
    print(f"Switched to '{name}': {display} <{email}>{saved_str(creds_path)}")
    print("Restart Claude Code for changes to take effect.")


def cmd_list():
    if not os.path.isdir(PROFILES_DIR):
        print("No profiles saved yet.")
        return

    profiles = sorted(d for d in os.listdir(PROFILES_DIR)
                      if os.path.isdir(os.path.join(PROFILES_DIR, d)))
    if not profiles:
        print("No profiles saved yet.")
        return

    current_email = None
    try:
        current_email = read_claude_json().get("oauthAccount", {}).get("emailAddress")
    except Exception:
        pass

    for name in profiles:
        pdir = os.path.join(PROFILES_DIR, name)
        try:
            with open(os.path.join(pdir, "account.json")) as f:
                info = json.load(f)
            email = info.get("oauthAccount", {}).get("emailAddress", "?")
            display = info.get("oauthAccount", {}).get("displayName", "")
            active = " (active)" if email == current_email else ""
            creds_path = profile_creds_path(pdir)
            tier = ""
            if creds_path:
                try:
                    with open(creds_path) as f:
                        tier = json.loads(f.read()).get("claudeAiOauth", {}).get("rateLimitTier", "")
                except Exception:
                    pass
            saved = saved_str(creds_path) if creds_path else ""
            print(f"  {name:<16} {display} <{email}> [{tier}]{saved}{active}")
        except Exception:
            print(f"  {name:<16} (corrupt profile)")


def cmd_rm(name):
    validate_name(name)
    pdir = profile_dir(name)
    if not os.path.isdir(pdir):
        print(f"Profile '{name}' not found.", file=sys.stderr)
        sys.exit(1)

    shutil.rmtree(pdir)
    print(f"Removed profile '{name}'.")


def cmd_rename(old, new):
    validate_name(old)
    validate_name(new)
    old_dir = profile_dir(old)
    new_dir = profile_dir(new)
    if not os.path.isdir(old_dir):
        print(f"Profile '{old}' not found.", file=sys.stderr)
        sys.exit(1)
    if os.path.exists(new_dir):
        print(f"Profile '{new}' already exists.", file=sys.stderr)
        sys.exit(1)
    os.rename(old_dir, new_dir)
    print(f"Renamed profile '{old}' to '{new}'.")


def cmd_current():
    try:
        cdata = read_claude_json()
        acct = cdata.get("oauthAccount", {})
        email = acct.get("emailAddress", "unknown")
        display = acct.get("displayName", "")

        creds_data = read_credentials()
        tier = ""
        if creds_data:
            tier = json.loads(creds_data).get("claudeAiOauth", {}).get("rateLimitTier", "")

        print(f"{display} <{email}> [{tier}]")
    except Exception as e:
        print(f"Could not read current account: {e}", file=sys.stderr)
        sys.exit(1)


def main():
    if len(sys.argv) < 2:
        print(__doc__.strip())
        sys.exit(0)

    args = sys.argv[1:]
    yes = False
    for flag in ("-y", "--yes"):
        if flag in args:
            args.remove(flag)
            yes = True

    if not args:
        print(__doc__.strip())
        sys.exit(1)
    cmd = args[0]

    if cmd == "save" and len(args) == 2:
        cmd_save(args[1], force=yes)
    elif cmd == "use" and len(args) == 2:
        cmd_use(args[1])
    elif cmd == "refresh" and len(args) == 2:
        cmd_refresh(args[1])
    elif cmd == "list" and len(args) == 1:
        cmd_list()
    elif cmd == "rm" and len(args) == 2:
        cmd_rm(args[1])
    elif cmd == "rename" and len(args) == 3:
        cmd_rename(args[1], args[2])
    elif cmd == "current" and len(args) == 1:
        cmd_current()
    else:
        print(__doc__.strip())
        sys.exit(1)


if __name__ == "__main__":
    main()
